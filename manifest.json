{
  "manifest_version": 3,
  "name": "Playback Rate Unlocker",
  "version": "1.0",
  "description": "Bypasses playback rate limits on e-learning platforms",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [{
    "matches": ["*://*.easyllama.com/*", "*://*.go1static.com/*", "*://*.mygo1.com/*"],
    "js": ["content.js"],
    "all_frames": true,
    "run_at": "document_start"
  }]
}
